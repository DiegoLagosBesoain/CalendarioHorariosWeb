# ============ SERVIDOR ============
PORT=3000

# ============ GOOGLE APPS SCRIPT ============
# URL del deployment de Google Apps Script (Web App URL)
APPSCRIPT_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec
# Clave compartida para autenticar requests al Apps Script
APPSCRIPT_KEY=tu_clave_secreta
# ID del Google Sheet (se encuentra en la URL del spreadsheet)
GOOGLE_SHEET_ID=tu_google_sheet_id

# ============ CORS ============
# Orígenes permitidos (separados por coma). En producción, usar el dominio real.
# Ejemplo: https://tu-dominio.com,https://www.tu-dominio.com
CORS_ORIGINS=http://localhost:5173

# ============ AUTENTICACION ============
# Clave obligatoria para habilitar registro de nuevos usuarios.
# Esta clave se solicita en la pantalla de registro como "Clave admin".
ADMIN_REGISTRATION_PASSWORD=cambia_esto_en_produccion

# ============ BASE DE DATOS (PostgreSQL) ============
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uandes
DB_USER=app_user
DB_PASSWORD=app_password
